    %% External traffic
    client -->|"HTTPS"| proxy
    proxy -->|"api.{domain}"| backend
    proxy -->|"dashboard.{domain}"| frontend
    proxy -->|"adminer.{domain}"| adminer

    %% Startup dependency chain
    db -->|"healthy"| prestart
    prestart -->|"completed"| loaddata
    prestart -->|"completed"| backend
    db -->|"healthy"| loaddata
    db -->|"healthy"| backend
    db --> adminer

    %% Runtime connections
    backend -->|"SQL / SQLModel"| db
    backend -->|"SMTP"| mailcatcher
    frontend -->|"REST /api/v1"| backend

